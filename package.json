{
  "name": "tempora",
  "private": true,
  "scripts": {
    "dev": "dotenv -- turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "db:generate": "dotenv -- pnpm --filter @tempora/db generate",
    "db:migrate": "dotenv -- pnpm --filter @tempora/db migrate",
    "db:seed": "dotenv -- pnpm --filter @tempora/db seed",
    "db:studio": "dotenv -- pnpm --filter @tempora/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.2.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
